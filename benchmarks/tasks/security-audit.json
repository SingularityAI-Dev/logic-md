{
	"name": "security-audit",
	"description": "Perform a security audit of code or infrastructure identifying vulnerabilities and severity levels",
	"category": "security",
	"complexity": "very-high",
	"input_type": "code-snippet",
	"input_file": "security-audit-sample.js",
	"expected_output_schema": {
		"type": "object",
		"required": ["vulnerabilities", "severity_summary", "remediation_plan", "risk_score"],
		"properties": {
			"vulnerabilities": {
				"type": "array",
				"minItems": 1,
				"items": {
					"type": "object",
					"required": [
						"id",
						"title",
						"severity",
						"cwe_id",
						"description",
						"location",
						"remediation"
					],
					"properties": {
						"id": { "type": "string", "pattern": "^[A-Z0-9]+$" },
						"title": { "type": "string" },
						"severity": {
							"type": "string",
							"enum": ["critical", "high", "medium", "low", "informational"]
						},
						"cwe_id": { "type": "string", "pattern": "^CWE-[0-9]+$" },
						"description": { "type": "string" },
						"location": {
							"type": "object",
							"properties": { "file": { "type": "string" }, "line": { "type": "number" } }
						},
						"remediation": { "type": "string" },
						"owasp_category": { "type": "string" }
					}
				},
				"description": "List of discovered vulnerabilities with CWE mappings"
			},
			"severity_summary": {
				"type": "object",
				"required": ["critical", "high", "medium", "low"],
				"properties": {
					"critical": { "type": "integer", "minimum": 0 },
					"high": { "type": "integer", "minimum": 0 },
					"medium": { "type": "integer", "minimum": 0 },
					"low": { "type": "integer", "minimum": 0 }
				},
				"description": "Count of vulnerabilities by severity"
			},
			"remediation_plan": {
				"type": "array",
				"items": {
					"type": "object",
					"required": ["priority", "action", "effort"],
					"properties": {
						"priority": { "type": "integer", "minimum": 1, "maximum": 5 },
						"action": { "type": "string" },
						"effort": { "type": "string", "enum": ["low", "medium", "high"] },
						"timeline": { "type": "string" }
					}
				},
				"description": "Prioritized remediation steps"
			},
			"risk_score": {
				"type": "number",
				"minimum": 0,
				"maximum": 100,
				"description": "Overall risk score (0-100)"
			},
			"compliance_notes": {
				"type": "array",
				"items": { "type": "string" },
				"description": "Relevant compliance or framework notes"
			}
		}
	},
	"control_prompt": "You are a security auditor. Analyze the provided code for security vulnerabilities. Identify issues, map them to CWE IDs, and provide a risk assessment with remediation steps.",
	"treatment_spec": "security-audit.logic.md",
	"timeout_ms": 40000,
	"retry_on_failure": true,
	"max_retries": 2
}
