{
	"name": "logic-md-benchmarks",
	"version": "1.0.0",
	"description": "Benchmark framework for LOGIC.md - comparing structured output quality with and without LOGIC.md contracts",
	"type": "module",
	"bin": {
		"logic-md-bench": "run.mjs"
	},
	"scripts": {
		"benchmark": "node run.mjs",
		"benchmark:dry-run": "node run.mjs --dry-run",
		"benchmark:verbose": "node run.mjs --verbose",
		"benchmark:code-review": "node run.mjs --task=code-review --dry-run"
	},
	"dependencies": {
		"ajv": "^8.12.0"
	},
	"optionalDependencies": {
		"@anthropic-ai/sdk": "^0.20.9",
		"openai": "^4.104.0"
	},
	"keywords": [
		"logic-md",
		"benchmarks",
		"ai-agents",
		"reasoning",
		"structured-output",
		"quality-gates"
	],
	"author": "LOGIC.md Contributors",
	"license": "MIT"
}
