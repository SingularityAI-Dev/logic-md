{
	"name": "@logic-md/langgraph-adapter",
	"version": "1.0.0-experimental.0",
	"description": "Experimental adapter: compile LOGIC.md specs into LangGraph StateGraph definitions",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"private": true,
	"devDependencies": {
		"@types/node": "^22.0.0",
		"typescript": "~5.8.0",
		"vitest": "~4.1.0"
	},
	"dependencies": {
		"@logic-md/core": "workspace:*"
	},
	"peerDependencies": {
		"@langchain/langgraph": ">=0.0.1"
	},
	"peerDependenciesMeta": {
		"@langchain/langgraph": {
			"optional": true
		}
	},
	"license": "MIT"
}
